{
  "identifier": "default",
  "description": "Default capabilities for PocketStream Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "shell:allow-open",
    "dialog:default",
    "notification:default",
    {
      "identifier": "core:app:default",
      "allow": []
    },
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized"
  ]
}
